# 数据库
DATABASE_URL=sqlite:///./data/knowledge.db

# 向量数据库
VECTOR_DB_PATH=./data/vectors

# 文件存储
UPLOAD_PATH=./data/uploads

# 服务
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 缓存相似度阈值（MOM制造术语变化小，建议0.85-0.90）
CACHE_SIMILARITY_THRESHOLD=0.90

# 密钥加密（用于加密模型API Key，同时用于 JWT 签名）
SECRET_KEY=change-this-in-production-please-use-a-long-random-string

# 认证配置（生产环境设为 true 启用 JWT 认证，保护敏感 API）
AUTH_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_EXPIRE_HOURS=24
