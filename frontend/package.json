{
  "name": "mom-ai-knowledge-base",
  "version": "1.0.0",
  "description": "MOM系统AI知识库平台前端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
